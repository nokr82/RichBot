# ===== Database =====
# Docker PostgreSQL 컨테이너 비밀번호
POSTGRES_PASSWORD=your_strong_password_here

# ===== Backend =====
# 로컬 개발용 (Docker 없이)
# DATABASE_URL=sqlite+aiosqlite:///./richbot.db

# DART OpenAPI - 금융감독원 전자공시
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=

# Anthropic Claude API
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Web Push VAPID Keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@yoursite.com

# Scheduler interval (minutes)
SCHEDULER_INTERVAL_MINUTES=15

# ===== Frontend (.env.local) =====
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=<same as VAPID_PUBLIC_KEY above>
